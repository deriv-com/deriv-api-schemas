{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "title": "Auto List Strategies (response)",
  "description": "List of available automated trading strategies",
  "type": "object",
  "required": ["echo_req", "msg_type"],
  "properties": {
    "auto_list_strategies": {
      "title": "auto_list_strategies",
      "description": "List of available automated trading strategies",
      "type": "object",
      "additionalProperties": false,
      "required": ["strategies"],
      "properties": {
        "strategies": {
          "description": "Array of available strategies",
          "type": "array",
          "items": {
            "description": "Details of an automated trading strategy",
            "type": "object",
            "additionalProperties": false,
            "required": [
              "display_name",
              "parameters",
              "strategy_id",
              "supported_contract_types"
            ],
            "properties": {
              "description": {
                "description": "Description of how the strategy works",
                "type": "string"
              },
              "display_name": {
                "description": "Human-readable name of the strategy",
                "type": "string"
              },
              "parameters": {
                "description": "Schema of parameters accepted by this strategy",
                "type": "object"
              },
              "strategy_id": {
                "description": "Unique identifier for the strategy",
                "type": "string"
              },
              "supported_contract_types": {
                "description": "Contract types that this strategy supports",
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "echo_req": {
      "description": "Echo of the request made.",
      "type": "object"
    },
    "msg_type": {
      "description": "Action name of the request made.",
      "type": "string",
      "enum": ["auto_list_strategies"]
    },
    "req_id": {
      "description": "Optional field sent in request to map to response, present only when request contains `req_id`.",
      "type": "integer"
    }
  }
}
