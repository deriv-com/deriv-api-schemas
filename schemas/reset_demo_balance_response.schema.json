{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Reset Demo Balance Response",
  "description": "Response after resetting demo account balance",
  "type": "object",
  "properties": {
    "data": {
      "type": "object",
      "properties": {
        "account_id": {
          "type": "string",
          "description": "Account ID",
          "example": "DOT90004580"
        },
        "balance": {
          "type": "number",
          "description": "New account balance (reset to default)",
          "example": 10000
        },
        "currency": {
          "type": "string",
          "description": "Account currency",
          "example": "USD"
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "description": "Account status",
          "example": "active"
        },
        "account_type": {
          "type": "string",
          "enum": ["demo"],
          "description": "Account type (only demo accounts can be reset)",
          "example": "demo"
        },
        "created_at": {
          "type": "string",
          "description": "Creation date"
        },
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "last_access_at": {
          "type": "string",
          "description": "Last access date"
        },
        "name": {
          "type": "string",
          "description": "Client name"
        },
        "server_id": {
          "type": "string",
          "description": "Server ID"
        },
        "rights": {
          "type": "object",
          "properties": {},
          "description": "User's rights"
        }
      },
      "required": ["account_id", "balance", "currency"]
    },
    "meta": {
      "type": "object",
      "properties": {
        "endpoint": {
          "type": "string",
          "description": "The current endpoint"
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "DELETE"],
          "description": "The current HTTP request method",
          "example": "POST"
        },
        "timing": {
          "type": "integer",
          "description": "Time for the API to serve the request"
        }
      },
      "required": ["endpoint", "method", "timing"]
    }
  }
}
